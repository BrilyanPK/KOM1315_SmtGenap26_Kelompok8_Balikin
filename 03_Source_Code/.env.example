# Gunakan URL PostgreSQL lokal atau Cloud (Supabase/Neon)
# Contoh Supabase: postgresql://postgres.[YOUR-PROJECT-ID]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.ktfrbgdvslwczgvihhqr.supabase.co:5432/postgres"

# Kunci Keamanan
SECRET_KEY="generate_dengan_openssl_rand_hex_32"
ENCRYPTION_KEY="generate_dengan_fernet_generate_key"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# Supabase Storage (untuk upload foto)
# Gunakan service_role key (bukan anon key) karena upload dilakukan dari backend
SUPABASE_URL=https://[YOUR-PROJECT-ID].supabase.co
SUPABASE_KEY=[YOUR-SERVICE-ROLE-KEY]
SUPABASE_BUCKET=uploads

# CORS (Domain Frontend)
FRONTEND_URL="https://balikin-ads2026-kelompok11.vercel.app/"

# Konfigurasi SMTP untuk MFA (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=emailkamu@gmail.com
SMTP_PASSWORD=app_password_16_digit
SMTP_FROM_EMAIL=emailkamu@gmail.com